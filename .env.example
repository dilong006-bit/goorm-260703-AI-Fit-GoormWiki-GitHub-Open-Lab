# 조회할 GitHub 사용자명
VITE_GITHUB_USERNAME=dilong006-bit

# GitHub Personal Access Token (선택) — Rate Limit 완화용 (시간당 60 → 5000회)
# https://github.com/settings/tokens 에서 Fine-grained token (Public repos Read-only) 발급
VITE_GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────
# Multi-LLM 콘텐츠 스튜디오 (Phase 3) — 모두 선택 사항
# 키가 하나도 없으면 자동으로 mock(시뮬레이션)으로 동작합니다.
# ⚠️ VITE_ 접두사 키는 브라우저 번들에 노출됩니다. 공개 배포 시에는
#    서버리스 프록시 사용을 권장합니다 (ref/SPEC-Phase3 §7).
# ─────────────────────────────────────────────────────────────
VITE_OPENAI_KEY=
VITE_CLAUDE_KEY=
VITE_GEMINI_KEY=
VITE_PERPLEXITY_KEY=
